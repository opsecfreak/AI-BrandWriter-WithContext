// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subtasks    Subtask[]
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  estimatedTime String
  priority  String   @default("low") // Can be "low", "medium",
  completed Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AgentReply {
  id          String   @id @default(cuid())
  agentType   String   // "task" or "writer"
  userPrompt  String
  openaiResponse String @db.Text
  processedOutput String? @db.Text
  brandContextId String?
  
  // Social Media specific fields
  topic       String?  // The main topic/subject
  tone        String?  // professional, casual, etc.
  targetAudience String? // Specific audience for this content
  keyMessage  String?  // Main message to convey
  callToAction String? // CTA used
  hashtags    String?  // Hashtags used
  additionalContext String? // Extra context for this generation
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  brandContext BrandContext? @relation(fields: [brandContextId], references: [id])
  publishLogs  PostPublishLog[]
}

model BrandContext {
  id              String   @id @default(cuid())
  businessName    String
  industry        String?
  targetAudience  String?
  brandVoice      String?  // casual, professional, friendly, etc.
  keyProducts     String?  // JSON array of products/services
  brandValues     String?  // JSON array of core values
  competitors     String?  // JSON array of competitors
  uniqueSellingPoints String? // What makes them different
  brandColors     String?  // hex codes or color names
  brandKeywords   String?  // JSON array of important keywords
  website         String?
  socialMediaHandles String? // JSON object with platform: handle
  additionalContext String? @db.Text // Any other important context
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  agentReplies    AgentReply[]
  socialAccounts  SocialAccount[]
}

// Connected social / publishing accounts per brand (initially Twitter only)
model SocialAccount {
  id                String   @id @default(cuid())
  provider          String   // e.g. 'twitter'
  providerAccountId String?  // External user id
  handle            String?  // @handle for quick reference
  displayName       String?
  accessToken       String?  // OAuth user access token (store encrypted in production)
  refreshToken      String?  // For providers supporting refresh
  tokenExpiresAt    DateTime?
  scopes            String?  // space/comma-delimited scope list
  metadata          Json?    // Provider-specific JSON blob
  brandContextId    String
  brandContext      BrandContext @relation(fields: [brandContextId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publishLogs       PostPublishLog[]
}

// Log of outbound publish attempts to external platforms
model PostPublishLog {
  id              String   @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  agentReplyId    String?
  agentReply      AgentReply? @relation(fields: [agentReplyId], references: [id], onDelete: SetNull)
  platform        String   // redundant but convenient (mirrors provider)
  status          String   // 'pending' | 'success' | 'failed'
  externalPostId  String?  // id/URL/reference returned by provider
  errorMessage    String?
  requestPayload  String?  @db.Text
  responsePayload String?  @db.Text
  createdAt       DateTime @default(now())
  completedAt     DateTime?
}